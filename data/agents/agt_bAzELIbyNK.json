{
  "id": "agt_bAzELIbyNK",
  "name": "Research Writer",
  "description": "Orchestrator + workers research agent with compaction and external memory.",
  "version": "0.1.0",
  "createdAt": "2026-07-19T05:14:20.641Z",
  "updatedAt": "2026-07-19T05:14:20.641Z",
  "core": {
    "goal": "Research a topic and produce a short cited brief.",
    "systemPrompt": "You are a research lead. Break work into subtasks. Prefer JIT retrieval. Write decisions to memory. Summarize sources; do not invent citations.",
    "exitCondition": "Brief delivered with sources, or budget exhausted with partial brief.",
    "ruleZero": true
  },
  "s1_orchestration": {
    "pattern": "orchestrator_workers",
    "nested": {
      "router": false,
      "workers": true,
      "judge": true
    },
    "chainSteps": [
      {
        "id": "step_1",
        "name": "Understand",
        "prompt": "Restate the goal and constraints."
      },
      {
        "id": "step_2",
        "name": "Plan",
        "prompt": "List the minimal steps needed."
      },
      {
        "id": "step_3",
        "name": "Execute",
        "prompt": "Do the work using tools if needed."
      },
      {
        "id": "step_4",
        "name": "Verify",
        "prompt": "Check the exit condition. Summarize outcome."
      }
    ],
    "routes": [
      {
        "id": "route_default",
        "name": "Default",
        "match": "default",
        "prompt": ""
      }
    ],
    "workerPrompt": "Complete the assigned subtask. Return a clean, structured result only.",
    "judgeCriteria": "Pass if claims have sources and brief answers the question.",
    "escalationRule": "Always agentic for open research."
  },
  "s2_context": {
    "systemPromptAltitude": "heuristics",
    "jitContext": true,
    "compactionThreshold": 0.7,
    "compactionKeep": [
      "decisions",
      "constraints",
      "todos",
      "open_threads"
    ],
    "externalMemory": true,
    "pointers": [],
    "seedNotes": []
  },
  "s3_tools": {
    "enabledToolIds": [
      "web_search",
      "memory_write",
      "memory_read",
      "write_file"
    ],
    "customTools": [],
    "returnStyle": "actionable"
  },
  "s4_guardrails": {
    "permissions": "least_privilege",
    "validateInput": true,
    "validateOutput": true,
    "breakers": {
      "maxSpendUsd": 1.5,
      "maxLoops": 12,
      "maxTimeSec": 300
    },
    "worstCase3am": "Publishes uncited claims as fact."
  },
  "s5_instruments": {
    "traces": true,
    "evals": [
      {
        "id": "ev1",
        "name": "Quick brief",
        "input": "Write a brief on prompt caching benefits for agents.",
        "expected": "contains:Result"
      }
    ],
    "driftNeedles": [
      "success_rate",
      "takeover_rate",
      "cost_per_task"
    ],
    "outcomeGrading": true
  },
  "s6_power": {
    "modelMap": {
      "reason": "large",
      "classify": "small",
      "extract": "small",
      "format": "small",
      "summarize": "small",
      "judge": "large"
    },
    "promptCaching": true,
    "parallelWhereIndependent": true,
    "tokenBudget": 8000,
    "turnLimit": 12
  },
  "s7_chassis": {
    "checkpoints": true,
    "idempotentRetries": true,
    "maxRetries": 2,
    "degradedModes": true,
    "versionEverything": true,
    "timeoutsSec": 30
  },
  "checklist": {}
}